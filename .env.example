# URL base del backend Laravel.
# En desarrollo normalmente se usa:
# VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_URL=http://127.0.0.1:8000/api

# Endpoint principal de categorías.
# El frontend también puede probar endpoints alternativos si el backend responde 404 o 405.
VITE_CATEGORIES_ENDPOINT=/categories

# Endpoint alternativo opcional para categorías.
# Úsalo si el backend expone categorías como /ticket-categories.
VITE_TICKET_CATEGORIES_ENDPOINT=/ticket-categories
